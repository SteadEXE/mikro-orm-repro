{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2024",
    "lib": [
      "ES2024"
    ],
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@": [
        "./src"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "public",
  ],
}
